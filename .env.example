# Optional overrides — the app works with sensible defaults if unset.

# --- Database ---
# If DATABASE_URL is set, the app uses PostgreSQL (recommended for production/Render).
# If it's NOT set, the app falls back to a local SQLite file (zero setup, good for dev).
#
# Render Postgres gives you a URL like:
#   postgres://user:password@host:5432/dbname
# The app automatically normalizes "postgres://" to the SQLAlchemy-compatible
# "postgresql+psycopg2://" form, so you can paste Render's URL as-is.
DATABASE_URL=postgres://user:password@localhost:5432/skin_care_connect

# Only used when DATABASE_URL is NOT set (SQLite mode).
DATABASE_PATH=./data/app.db

# --- Model ---
# Path to the trained .h5 model. Defaults to ./models/skin_disease_model.h5
MODEL_PATH=./models/skin_disease_model.h5

